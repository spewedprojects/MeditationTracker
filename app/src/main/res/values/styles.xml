<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Group Shape (Outer Corners Rounded) -->
    <style name="ExportImportGroupShape" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">?attr/customButtonRadius</item>
    </style>

    <!-- Export Button Corners (Left Rounded, Right Square) -->
    <style name="StartButtonCorners">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">?attr/customButtonRadius</item>
        <item name="cornerSizeBottomLeft">?attr/customButtonRadius</item>
        <item name="cornerSizeTopRight">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <!-- Import Button Corners (Right Rounded, Left Square) -->
    <style name="EndButtonCorners">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopRight">?attr/customButtonRadius</item>
        <item name="cornerSizeBottomRight">?attr/customButtonRadius</item>
        <item name="cornerSizeTopLeft">0dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
    </style>

    <!-- Middle Button Corners (Right Square, Left Square) -->
    <style name="MiddleButtonCorners">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopRight">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
        <item name="cornerSizeTopLeft">0dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
    </style>

    <!-- Group Shape (Outer Corners Rounded) -->
    <style name="method_WMY_GroupShape" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">?attr/customButtonRadius</item>
    </style>

    <!-- Button Style (Shared Properties) -->
    <style name="method_WMY_Group_ButtonStyle" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">46dp</item>
        <item name="android:textColor">?attr/colorPrimary</item>
        <item name="android:textAppearance">?attr/textAppearanceAppButton</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="android:textSize">18sp</item>
        <item name="android:padding">0dp</item>
        <item name="android:gravity">center</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:includeFontPadding">false</item>
        <item name="backgroundTint">?attr/colorOnPrimary</item> <!-- Transparent background -->
        <item name="background">?attr/colorOnPrimary</item>
        <item name="strokeWidth">0dp</item> <!-- Remove border -->
    </style>

    <!-- Base Theme Overlay -->
    <style name="ThemeOverlay.MeditationTracker" parent="ThemeOverlay.MaterialComponents">
        <!-- You can put shared defaults here -->
        <!-- Example: -->
        <!-- <item name="colorPrimary">@color/meditation_primary</item> -->
    </style>

    <!-- Theme Overlays for Dynamic Radii -->
    <style name="ThemeOverlay.MeditationTracker.CardRadius12">
        <item name="customCardRadius">12dp</item>
    </style>
    <style name="ThemeOverlay.MeditationTracker.CardRadius24">
        <item name="customCardRadius">24dp</item>
    </style>
    <style name="ThemeOverlay.MeditationTracker.CardRadius36">
        <item name="customCardRadius">36dp</item>
    </style>

    <style name="ThemeOverlay.MeditationTracker.ButtonRadius10">
        <item name="customButtonRadius">10dp</item>
    </style>
    <style name="ThemeOverlay.MeditationTracker.ButtonRadius15">
        <item name="customButtonRadius">15dp</item>
    </style>
    <style name="ThemeOverlay.MeditationTracker.ButtonRadius20">
        <item name="customButtonRadius">20dp</item>
    </style>

</resources>